# Application
APP_NAME=Tri9T AI CT-200 Backend
ENVIRONMENT=development

# Relational database (SQLite by default)
DATABASE_URL=sqlite:///./ct200.db

# Optional MongoDB settings; not contacted during application startup
MONGO_URI=
MONGO_DATABASE=ct200_generations

# Optional LLM settings; not required for Module 0
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
